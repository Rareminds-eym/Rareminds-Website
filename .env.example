# ============================================================================
# RAREMINDS WEBSITE - Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# For Vite, all variables must be prefixed with VITE_ to be exposed to the browser

# ============================================================================
# SUPABASE - Database & Authentication
# ============================================================================
# Development: Use local Supabase (requires supabase CLI)
# The values below connect to a local Supabase instance at http://127.0.0.1:54321
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

